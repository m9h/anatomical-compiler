<?xml version="1.0" encoding="UTF-8"?>
<sbml xmlns="http://www.sbml.org/sbml/level3/version2/core" level="3" version="2">
  <model metaid="lab1_positive_autoregulation" id="lab1_positive_autoregulation">
    <annotation>
      <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:vCard="http://www.w3.org/2001/vcard-rdf/3.0#" xmlns:vCard4="http://www.w3.org/2006/vcard/ns#" xmlns:bqbiol="http://biomodels.net/biology-qualifiers/" xmlns:bqmodel="http://biomodels.net/model-qualifiers/">
        <rdf:Description rdf:about="#lab1_positive_autoregulation">
          <bqmodel:isDescribedBy>
            <rdf:Bag>
              <rdf:li rdf:resource="https://identifiers.org/pubmed/11350942"/>
            </rdf:Bag>
          </bqmodel:isDescribedBy>
        </rdf:Description>
      </rdf:RDF>
    </annotation>
    <listOfCompartments>
      <compartment sboTerm="SBO:0000410" id="default_compartment" spatialDimensions="3" size="1" constant="true"/>
    </listOfCompartments>
    <listOfSpecies>
      <species sboTerm="SBO:0000252" id="x" compartment="default_compartment" initialConcentration="0.5" hasOnlySubstanceUnits="false" boundaryCondition="false" constant="false"/>
    </listOfSpecies>
    <listOfParameters>
      <parameter id="beta0" value="0.2" constant="true"/>
      <parameter id="K" value="1" constant="true"/>
      <parameter id="n" value="4" constant="true"/>
      <parameter id="gam" value="1" constant="true"/>
      <parameter id="beta" value="4" constant="true"/>
    </listOfParameters>
    <listOfReactions>
      <reaction sboTerm="SBO:0000176" id="J0" reversible="true">
        <listOfProducts>
          <speciesReference species="x" stoichiometry="1" constant="true"/>
        </listOfProducts>
        <kineticLaw>
          <math xmlns="http://www.w3.org/1998/Math/MathML">
            <apply>
              <minus/>
              <apply>
                <plus/>
                <ci> beta0 </ci>
                <apply>
                  <divide/>
                  <apply>
                    <times/>
                    <ci> beta </ci>
                    <apply>
                      <power/>
                      <apply>
                        <divide/>
                        <ci> x </ci>
                        <ci> K </ci>
                      </apply>
                      <ci> n </ci>
                    </apply>
                  </apply>
                  <apply>
                    <plus/>
                    <cn type="integer"> 1 </cn>
                    <apply>
                      <power/>
                      <apply>
                        <divide/>
                        <ci> x </ci>
                        <ci> K </ci>
                      </apply>
                      <ci> n </ci>
                    </apply>
                  </apply>
                </apply>
              </apply>
              <apply>
                <times/>
                <ci> gam </ci>
                <ci> x </ci>
              </apply>
            </apply>
          </math>
        </kineticLaw>
      </reaction>
    </listOfReactions>
  </model>
</sbml>
