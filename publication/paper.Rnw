anthro_modules <- g(tryCatch(J$anthro$n_modules,           error = function(e) NULL), 236)
park_p_str     <- fmt_p(g(tryCatch(J$microglia$park_p,     error = function(e) NULL), 1.05e-14))
popova_max     <- g(tryCatch(max(J$microglia$popova_modularity$n_modules), error = function(e) NULL), 8)
