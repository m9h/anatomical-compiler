## ---- locate the repository root (robust to where knit is invoked from) -----
find_root <- function() {
  d <- normalizePath(getwd(), winslash = "/")
  for (i in 1:6) {
    if (file.exists(file.path(d, "pyproject.toml")) || dir.exists(file.path(d, ".git")))
      return(d)
    parent <- dirname(d); if (parent == d) break; d <- parent
  }
  normalizePath(getwd(), winslash = "/")
}
ROOT <- find_root()
fig  <- function(...) file.path(ROOT, "figures", ...)
dat  <- function(...) file.path(ROOT, "data", ...)

## ---- helpers --------------------------------------------------------------
have_jsonlite <- requireNamespace("jsonlite", quietly = TRUE)
load_json <- function(path) {
  if (!have_jsonlite || !file.exists(path)) return(NULL)
  tryCatch(jsonlite::fromJSON(path, simplifyVector = TRUE), error = function(e) NULL)
}
note_missing <- function(what)
  cat(sprintf("\\textit{[%s: result file not found --- run the corresponding \\texttt{scripts/benchmark\\_*.py} and re-knit.]}", what))
## scientific-notation p-value -> LaTeX math (e.g. 1.05e-14 -> $1.05\times10^{-14}$)
fmt_p <- function(p, sig = 2) {
  if (is.null(p) || is.na(p)) return("n/a")
  if (p == 0) return("$<10^{-300}$")
  e <- floor(log10(p)); m <- p / 10^e
  if (e >= -3 && e <= 0) return(sprintf("$%.*g$", sig + 1, p))
  sprintf("$%.*f\\times10^{%d}$", sig, m, e)
}
num <- function(x, d = 0) formatC(x, format = "f", big.mark = ",", digits = d)
ktab <- function(df, caption, label, align = NULL, digits = NULL) {
  cat(knitr::kable(df, format = "latex", booktabs = TRUE, escape = FALSE,
                   caption = caption, label = label, align = align, digits = digits,
                   linesep = ""))
}

## ---- pre-load the artifacts used by inline \Sexpr{} calls -----------------
