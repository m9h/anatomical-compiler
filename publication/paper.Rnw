\section*{Code and data availability}
%==============================================================================
\hgx: \url{https://github.com/m9h/hgx}. \devograph: \url{https://github.com/m9h/devograph}.
Benchmark code, preprocessing pipelines, and per-dataset result files:
\url{https://github.com/m9h/anatomical-compiler}. Organoid GRN: Zenodo
\href{https://doi.org/10.5281/zenodo.5242913}{10.5281/zenodo.5242913}. Neocortex Atlas:
NeMO Analytics (\url{https://nemoanalytics.org/landing/neocortex/}); SJD
(\url{https://github.com/CHuanSite/SJD}); projectR (Bioconductor). A Colab notebook
reproduces the core analyses (A100 runtime). NITMB: National Institute for Theory and
Mathematics in Biology (Northwestern University \& University of Chicago).
This manuscript is a knitr/Sweave document (\texttt{publication/paper.Rnw}); result tables
and inline values are pulled live from \texttt{figures/*\_results.json} (Python/JAX analyses)
and \texttt{data/cropseq/*.csv} (R/Seurat differential expression).

\paragraph{Computational environment.}
<<env, eval=TRUE>>=
cat("\\begin{itemize}\n")
cat(sprintf("\\item %s; knitr %s, jsonlite %s\n",
            R.version.string,
            as.character(utils::packageVersion("knitr")),
            if (have_jsonlite) as.character(utils::packageVersion("jsonlite")) else "absent"))
py_line <- tryCatch({
  if (requireNamespace("reticulate", quietly = TRUE) && reticulate::py_available(initialize = TRUE)) {
    cfg <- reticulate::py_config()
    mods <- vapply(c("numpy","scanpy","jax"), function(m)
      if (reticulate::py_module_available(m)) "yes" else "no", character(1))
    sprintf("\\item Python %s; numpy=%s, scanpy=%s, jax=%s (used by \\texttt{scripts/benchmark\\_*.py} to regenerate \\texttt{figures/*\\_results.json})",
            cfg$version, mods["numpy"], mods["scanpy"], mods["jax"])
  } else "\\item Python/reticulate not configured in this knit; result JSONs are read as-is."
}, error = function(e) "\\item Python/reticulate not available in this knit; result JSONs are read as-is.")
cat(py_line, "\n")
cat("\\end{itemize}\n")
@

