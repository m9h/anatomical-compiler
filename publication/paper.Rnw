  anthro    = load_json(fig("anthrobot_results.json")),
  atlas     = load_json(fig("neocortex_atlas_results.json")),
  learn     = load_json(fig("learning_regulome_results.json")),
  control   = load_json(fig("network_control_results.json")),
  anacomp   = load_json(fig("anatomical_compiler_results.json"))
)
## small accessors with literal fallbacks (so the prose still reads if a file is absent)
g  <- function(x, default) if (is.null(x) || (length(x) == 1 && is.na(x))) default else x
atlas_shared   <- g(tryCatch(J$atlas$shared_genes,         error = function(e) NULL), 15412)
atlas_p2       <- g(tryCatch(round(J$atlas$mean_scores$p2), error = function(e) NULL), 188)
atlas_p5       <- g(tryCatch(round(J$atlas$mean_scores$p5), error = function(e) NULL), 277)
