# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Large data (Zenodo raw, expression matrices, old processed)
data/zenodo/
data/expression/
data/processed_old/

# Large per-dataset downloads / processed objects (regenerate via scripts/download_*.py + preprocess_*.py)
data/bioprinting/
data/agency/
data/azbukina/
data/krienen/
data/mouse/
data/zscape/
data/choose/extracted_rds/
data/choose/processed_real/
data/choose/CHOOSE_filtered.h5ad*
data/pollen/*.h5ad
data/choose/*.rds
data/choose/processed/data.mtx
data/choose/processed/cells.txt
*.h5ad
*.h5ad.gz
data/Sonthalia_Table3.xlsx
# (keep small text/csv/json inputs: data/cropseq/*.csv, data/disease_gene_lists.json,
#  data/SonthaliaEtAl_SupplTable3_*.txt — add explicitly if large)

# Trained models / checkpoints (large; per-user / per-machine caches).
# Use `models/*` (not `models/`) so the un-ignore patterns below can re-include
# specific files — git won't re-include from a wholly-excluded directory.
models/*
# …except hand-curated source-of-truth model files (Antimony / SBML / CellML
# / MorpheusML — small text, intentional commit artifacts per docs/cure-audit.md).
!models/*.ant
!models/*.sbml
!models/*.xml
!models/*.cellml
!models/README.md

# OS / coverage / scratch
.DS_Store
.coverage
.pytest_cache/
tmp/

# Claude memory (private)
.claude/

# LaTeX build artifacts (keep .tex/.Rnw and the committed .pdf)
*.aux
*.toc
*.out
*.log
*.synctex.gz
*.bbl
*.blg
publication/*.knit.*

